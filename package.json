{
  "name": "n8n-nodes-submitrax",
  "version": "0.1.9",
  "description": "n8n node for Submitrax",
  "keywords": [
    "n8ncommunity-node-package"
  ],
  "license": "MIT",
  "homepage": "https://submitrax.com",
  "author": {
    "name": "Submitrax",
    "email": "hello@submitrax.com"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SubmitraxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Submitrax/Submitrax.node.js",
      "dist/nodes/Submitrax/SubmitraxTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/parser": "~5.45",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "@n8n/node-cli": "^0.23.0",
    "n8n-core": "*",
    "n8n-workflow": "*",
    "prettier": "^2.7.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}